n = int(input())
m = int(input())
flag = False
for i in range(1, n):
    a = i
    for k in range(1, n):
        b = k
        for j in range(1, n):
            c = j
            if a+3*b+2*c == m:
                print(f'{a} + 3×{b} + 2×{c} = {m}')
                flag = True
if flag == False:
    print('При заданных n и m решений не существует.')
